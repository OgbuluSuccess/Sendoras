{
  "name": "sendoras-trailer",
  "version": "1.0.0",
  "description": "Remotion video project for recording the Sendora app",
  "scripts": {
    "preview": "remotion preview src/index.ts",
    "render:desktop": "remotion render src/index.ts DesktopVideo out/sendoras-desktop.mp4",
    "render:mobile": "remotion render src/index.ts MobileVideo out/sendoras-mobile.mp4",
    "render:both": "npm run render:desktop && npm run render:mobile"
  },
  "dependencies": {
    "remotion": "^4.0.241",
    "@remotion/renderer": "^4.0.241",
    "@remotion/cli": "^4.0.241",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
